# Copy this file to .env and fill in your values
# NEVER commit the .env file — it's in .gitignore

# ── AWS Credentials ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── EC2 Config ───────────────────────────────────────────────
EC2_KEY_NAME=your_key_pair_name          # Name of your AWS key pair
EC2_KEY_PATH=~/.ssh/your_key.pem         # Local path to the .pem file
EC2_SECURITY_GROUP=your_security_group   # SG that allows SSH (port 22) + app port
EC2_DEFAULT_AMI=ami-0c02fb55956c7d316    # Amazon Linux 2 (us-east-1)

# ── API Config ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
